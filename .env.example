# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# CoinGecko API key (Demo plan) — https://www.coingecko.com/en/api
# The app works without a key but may hit rate limits.
COINGECKO_API_KEY=your_coingecko_demo_api_key_here
